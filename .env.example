# Public client-safe values
# Used by Supabase browser and server auth clients.
# Local Supabase may print a publishable key; use it here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values
# Never expose these through NEXT_PUBLIC_ variables or client components.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Billing values, added in the billing milestone.
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LITE_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Resend email values, added in the email milestone.
RESEND_API_KEY=
EMAIL_FROM=

# Optional server-only AI assistant values.
# Set AI_FEATURES_ENABLED=false to disable the assistant without removing the keys.
AI_FEATURES_ENABLED=false
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_AI_MODEL=deepseek-ai/deepseek-v4-flash
