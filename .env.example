# Public client-safe values
# Used by Supabase browser and server auth clients.
# Local Supabase may print a publishable key; use it here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values
# Never expose these through NEXT_PUBLIC_ variables or client components.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Billing values, added in the billing milestone.
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LITE_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Resend email values, added in the email milestone.
RESEND_API_KEY=
EMAIL_FROM=

# Deferred server-only AI provider values will be added when Milestone 9 is implemented.
